# Production-style Compose environment. Copy to .env.prod and replace values before running prod commands.

HTTP_HOST_PORT=8080
POSTGRES_VERSION=17
POSTGRES_USER=agent_chat
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_DB=agent_chat
DATABASE_URL=postgres://agent_chat:replace-with-postgres-password@postgres:5432/agent_chat

# Empty VITE_CHAT_API_URL means the SPA uses same-origin requests through Caddy.
VITE_CHAT_API_URL=
BETTER_AUTH_URL=http://127.0.0.1:8080/api/auth
CHAT_UI_ORIGIN=http://127.0.0.1:8080

OPENAI_API_KEY=replace-with-openai-key

DOCUMENT_OBJECT_STORE_ENDPOINT=https://object-storage.example
DOCUMENT_OBJECT_STORE_BUCKET=vivd-catalyst-documents
DOCUMENT_OBJECT_STORE_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-with-object-storage-access-key
AWS_SECRET_ACCESS_KEY=replace-with-object-storage-secret-key
DOCUMENT_WORKER_TOKEN=replace-with-at-least-32-random-characters
DOCUMENT_WORKER_CONCURRENCY=2

BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
DEMO_SUPERADMIN_EMAIL=superadmin@example.test
DEMO_SUPERADMIN_PASSWORD=replace-with-superadmin-password
DEMO_USER_EMAIL=user@example.test
DEMO_USER_PASSWORD=replace-with-user-password

CHAT_SESSION_TOKEN_SECRET=replace-with-at-least-24-random-characters
CHAT_SERVER_CREDENTIAL=replace-with-server-to-server-secret
