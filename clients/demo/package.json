{
  "name": "@vivd-catalyst/demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/server.ts src/seed-auth.ts src/artifact-preview-worker.ts --format esm --out-dir dist && vite build",
    "build:server": "tsup src/server.ts src/seed-auth.ts src/artifact-preview-worker.ts --format esm --out-dir dist",
    "build:ui": "vite build",
    "config:push": "node ../../packages/config-cli/dist/index.js config push --dir . --force",
    "dev": "docker compose watch api ui artifact-preview-worker",
    "dev:down": "docker compose down",
    "dev:db": "docker compose up -d postgres",
    "dev:prod": "docker compose --env-file .env.prod -f docker-compose.prod.yml up --build",
    "prod:config": "docker compose --env-file .env.prod -f docker-compose.prod.yml config",
    "dev:ui": "vite --host 0.0.0.0 --port 5173",
    "preview:ui": "vite preview --host 127.0.0.1 --port 5173 --outDir dist/client",
    "seed:auth": "docker compose run --rm api node clients/demo/dist/seed-auth.js",
    "start": "node dist/server.js",
    "start:artifact-preview-worker": "node dist/artifact-preview-worker.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vivd-catalyst/chat-ui": "workspace:*",
    "@vivd-catalyst/client-assembly": "workspace:*",
    "@vivd-catalyst/tool-sdk": "workspace:*",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
