{
  "name": "@vivd-catalyst/demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/server.ts --format esm --out-dir dist && vite build",
    "build:server": "tsup src/server.ts --format esm --out-dir dist",
    "build:ui": "vite build",
    "dev": "pnpm dev:db && concurrently -n api,ui -c cyan,green \"pnpm dev:api\" \"pnpm dev:ui\"",
    "dev:api": "tsx watch --conditions=development --clear-screen=false --include ../../packages --include tools --include agents --include config --include ../../.env --include .env src/server.ts",
    "dev:db": "docker compose up -d postgres",
    "dev:ui": "vite --host 127.0.0.1 --port 5173",
    "preview:ui": "vite preview --host 127.0.0.1 --port 5173 --outDir dist/client",
    "seed:auth": "pnpm dev:db && tsx src/seed-auth.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vivd-catalyst/client-assembly": "workspace:*",
    "@vivd-catalyst/chat-ui": "workspace:*",
    "@vivd-catalyst/tool-sdk": "workspace:*",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
