HOST=127.0.0.1
PORT=4100
CLIENT_CONFIG_PATH=config/app.yaml
# Either http://127.0.0.1:5173 or http://localhost:5173 works in development.
CHAT_UI_ORIGIN=http://127.0.0.1:5173

OPENAI_API_KEY=

# Required for standalone login, sessions, and persisted conversations.
DATABASE_URL=postgres://agent_chat:agent_chat@127.0.0.1:55432/agent_chat
RUN_MIGRATIONS=true
DOCUMENT_OBJECT_STORE_ENDPOINT=http://127.0.0.1:9090
DOCUMENT_OBJECT_STORE_BUCKET=vivd-catalyst-documents
AWS_ACCESS_KEY_ID=s3mock
AWS_SECRET_ACCESS_KEY=s3mock
DOCUMENT_WORKER_URL=http://127.0.0.1:4110
DOCUMENT_WORKER_TOKEN=dev-document-worker-token
DOCUMENT_WORKER_CONCURRENCY=2
BETTER_AUTH_URL=http://127.0.0.1:4100/api/auth
BETTER_AUTH_SECRET=replace-with-at-least-32-random-characters
DEMO_SUPERADMIN_EMAIL=superadmin@example.test
DEMO_SUPERADMIN_PASSWORD=demo-superadmin-password
DEMO_USER_EMAIL=user@example.test
DEMO_USER_PASSWORD=demo-user-password

# Optional embedded-chat token issuing.
CHAT_SESSION_TOKEN_SECRET=replace-with-at-least-24-random-characters
CHAT_SERVER_CREDENTIAL=replace-with-a-server-to-server-secret
