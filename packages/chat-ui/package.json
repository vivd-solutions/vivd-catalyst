{
  "name": "@vivd-catalyst/chat-ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.tsx",
      "import": "./dist/index.js"
    },
    "./shell": {
      "types": "./dist/shell.d.ts",
      "development": "./src/shell.tsx",
      "import": "./dist/shell.js"
    },
    "./admin": {
      "types": "./dist/admin.d.ts",
      "development": "./src/admin.tsx",
      "import": "./dist/admin.js"
    },
    "./vite": {
      "types": "./src/vite.d.ts",
      "import": "./src/vite.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.tsx src/shell.tsx src/admin.tsx --format esm --dts --external react --external react-dom",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.201",
    "@assistant-ui/react": "^0.14.16",
    "@assistant-ui/react-ai-sdk": "^1.3.33",
    "@assistant-ui/react-markdown": "^0.14.2",
    "@assistant-ui/react-syntax-highlighter": "^0.14.2",
    "@radix-ui/react-collapsible": "^1.1.13",
    "@radix-ui/react-slot": "^1.2.5",
    "@tanstack/react-query": "^5.101.0",
    "@vivd-catalyst/api-client": "workspace:*",
    "ai": "^6.0.199",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
