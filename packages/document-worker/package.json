{
  "name": "@vivd-catalyst/document-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vivd-catalyst/client-assembly": "workspace:*",
    "@vivd-catalyst/config-schema": "workspace:*",
    "@vivd-catalyst/core": "workspace:*",
    "@vivd-catalyst/document-processing": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@types/node": "^24.13.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
