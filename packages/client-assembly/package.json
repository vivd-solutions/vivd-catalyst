{
  "name": "@vivd-stage/client-assembly",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vivd-stage/agent-runtime": "workspace:*",
    "@vivd-stage/auth": "workspace:*",
    "@vivd-stage/core": "workspace:*",
    "@vivd-stage/chat-server": "workspace:*",
    "@vivd-stage/config-schema": "workspace:*",
    "@vivd-stage/model-provider": "workspace:*",
    "@vivd-stage/postgres-store": "workspace:*",
    "@vivd-stage/tool-execution": "workspace:*",
    "@vivd-stage/tool-sdk": "workspace:*",
    "@vivd-stage/usage-governance": "workspace:*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
