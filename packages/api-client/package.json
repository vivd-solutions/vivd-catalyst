{
  "name": "@vivd-catalyst/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "generate": "pnpm --filter @vivd-catalyst/api-contract generate:openapi && openapi-ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vivd-catalyst/api-contract": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "0.99.0",
    "@types/node": "^24.13.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
}
