    "@vivd-catalyst/config-schema": "workspace:*",
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.13.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  }
