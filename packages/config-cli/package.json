{
  "name": "@vivd-catalyst/config-cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "catalyst": "./dist/index.js"
  },
