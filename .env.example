HOST=127.0.0.1
PORT=4100
CLIENT_CONFIG_PATH=clients/demo/config/app.yaml

# Paste your real key into .env, not this example file.
OPENAI_API_KEY=

# Optional Postgres store. If omitted, the demo uses an in-memory store.
# DATABASE_URL=postgres://agent_chat:agent_chat@127.0.0.1:5432/agent_chat
RUN_MIGRATIONS=true

# Optional embedded-chat token issuing.
CHAT_SESSION_TOKEN_SECRET=replace-with-at-least-24-random-characters
CHAT_SERVER_CREDENTIAL=replace-with-a-server-to-server-secret
