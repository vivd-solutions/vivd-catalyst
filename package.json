{
  "name": "vivd-stage-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build && pnpm -r --filter './clients/*' build",
    "build:demo": "pnpm -r --filter './packages/*' build && pnpm --filter @vivd-stage/demo build",
    "build:immobilienaufbau": "pnpm -r --filter './packages/*' build && pnpm --filter @vivd-stage/immobilienaufbau build",
    "check": "pnpm typecheck && pnpm test && pnpm build",
    "dev": "pnpm dev:demo",
    "dev:demo": "pnpm --filter @vivd-stage/demo dev",
    "dev:immobilienaufbau": "pnpm --filter @vivd-stage/immobilienaufbau dev",
    "docs:build": "pnpm --filter @vivd-stage/docs build",
    "docs:dev": "pnpm --filter @vivd-stage/docs dev",
    "docs:preview": "pnpm --filter @vivd-stage/docs preview",
    "test": "vitest run",
    "test:e2e": "VITE_CHAT_API_URL=http://127.0.0.1:4210 pnpm build && playwright test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
